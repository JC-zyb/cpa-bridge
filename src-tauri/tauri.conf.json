{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cpa-bridge",
  "version": "0.1.0",
  "identifier": "com.github.zhayubin.cpa-bridge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "cpa-bridge",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5Mzc2Q0UzRjhFN0JGN0EKUldSNnYrZjQ0MnczNlQ1bXJXVnNsWU5FQ1NqY01DMEpNWm1MWkJPanF1R1YzenhCSFdmYll4M0cK",
      "endpoints": [
        "https://github.com/JC-zyb/cpa-bridge/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
